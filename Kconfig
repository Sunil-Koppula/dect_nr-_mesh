config CARRIER
	int "Carrier to use"
	default 0
	help
	   The availability of the channels and the exact regulation to use them varies in different countries.
	   See ETSI TS 103 636-2 5.4.2 for the calculation.
	   Band index 1 is set when the carrier is within the range of 525 to 551.
	   This is the only range allowed for band index 1 as other carriers will interfere with other radio devices, including LTE devices.

config NETWORK_ID
	int "Network ID"
	range 1 4294967295
	default 91

config MCS
	int "MCS"
	default 1
	help
	   The MCS impacts how much data can fit into each subslot.

config TX_POWER
	int "TX power"
	range 0 13
	default 13
	help
	   Transmission power, max 19 dBm due to hardware limitations.
	   See table 6.2.1-3 of ETSI TS 103 636-4 v1.5.1.

config RX_PERIOD_S
	int "RX period"
	default 5
	help
	   Receive window period.
	   Time is given in seconds.

config RADIO_LOG_LEVEL
	int "Radio log level"
	default 1

config ANCHOR_LOG_LEVEL
	int "Anchor log level"
	default 1

config GATEWAY_LOG_LEVEL
	int "Gateway log level"
	default 1

config SENSOR_LOG_LEVEL
	int "Sensor log level"
	default 1

config DISPLAY_LOG_LEVEL
	int "Display log level"
	default 1

config IDENTITY_LOG_LEVEL
	int "Identity log level"
	default 1

config LARGE_DATA_LOG_LEVEL
	int "Large data log level"
	default 1

config MAIN_LOG_LEVEL
	int "Main log level"
	default 1

config MESH_LOG_LEVEL
	int "Mesh log level"
	default 1

config NVS_STORE_LOG_LEVEL
	int "NVS store log level"
	default 1

config PSRAM_LOG_LEVEL
	int "PSRAM log level"
	default 1

config COMMON_LOG_LEVEL
	int "Common log level"
	default 1

config QUEUE_LOG_LEVEL
	int "Queue log level"
	default 1

module = DECT_PHY_MESH
module-str = DECT NR+ PHY Mesh
source "$(ZEPHYR_BASE)/subsys/logging/Kconfig.template.log_config"

menu "Zephyr Kernel"
source "Kconfig.zephyr"
endmenu
